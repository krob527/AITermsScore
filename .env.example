# ─────────────────────────────────────────────────────────────────────────────
# Azure AI Foundry – Project Configuration
# Copy this file to .env and fill in your own values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Azure AI Foundry project endpoint
# Found in: AI Foundry portal → your project → Overview → Project details
# Format:  https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://<hub-name>.services.ai.azure.com/api/projects/<project-name>

# Model deployment name inside the DevGenius project (e.g. gpt-4o, gpt-4.1)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Name to register/find the agent in AI Foundry (alphanumeric + hyphens, max 63 chars)
AGENT_NAME=AITermsScoreAgent

# Azure subscription (optional – used for display only)
AZURE_SUBSCRIPTION_ID=<subscription-id>
